@model List<UzukiWeb.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ Hàng Của Bạn";
}

<main class="container pb-5" style="margin-top: 110px; min-height: 80vh;">

    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-black m-0" style="color: #000066;"><i class="bi bi-cart3 text-primary me-3"></i> GIỎ HÀNG CỦA BẠN</h2>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
            <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" width="150" class="mb-3 opacity-50" alt="Empty Cart">
            <h4 class="fw-bold text-muted">Giỏ hàng đang trống</h4>
            <p class="text-muted mb-4">Bạn chưa chọn mua cuốn sách hay phụ kiện nào.</p>
            <a href="/Home/Shop" class="btn btn-primary rounded-pill fw-bold px-4 py-2 shadow-sm">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="ps-4">Sản Phẩm</th>
                                    <th scope="col" class="text-center">Đơn Giá</th>
                                    <th scope="col" class="text-center">Số Lượng</th>
                                    <th scope="col" class="text-end pe-4">Thành Tiền</th>
                                    <th scope="col"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <img src="~/images/@item.AnhBia" class="rounded shadow-sm me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                                <div class="fw-bold text-dark text-truncate" style="max-width: 200px;">@item.TenSanPham</div>
                                            </div>
                                        </td>
                                        <td class="text-center text-muted">@item.Gia.ToString("N0") đ</td>
                                        <td class="text-center fw-bold">x @item.SoLuong</td>
                                        <td class="text-end fw-black text-danger pe-4">@item.ThanhTien.ToString("N0") đ</td>
                                        <td class="text-center">
                                            <a href="/Home/RemoveFromCart?productId=@item.SanPhamId" class="btn btn-sm btn-outline-danger rounded-circle">
                                                <i class="bi bi-trash3"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <a href="/Home/Shop" class="btn btn-link text-decoration-none fw-bold mt-3"><i class="bi bi-arrow-left"></i> Tiếp tục chọn sách</a>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 100px;">
                    <h5 class="fw-bold mb-4 border-bottom pb-2"><i class="bi bi-receipt text-success me-2"></i> THÔNG TIN GIAO HÀNG</h5>

                    <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                        <span class="fs-5 fw-bold text-dark">Tổng tiền:</span>
                        <span class="fs-4 fw-black text-danger">@Model.Sum(x => x.ThanhTien).ToString("N0") đ</span>
                    </div>

                    @if (!User.Identity!.IsAuthenticated)
                    {
                        <div class="alert alert-warning text-center small fw-bold mt-2">
                            Vui lòng đăng nhập để tiến hành đặt hàng!
                        </div>
                        <a href="/Account/Login" class="btn btn-primary w-100 rounded-pill fw-bold py-2">Đăng Nhập Ngay</a>
                    }
                    else
                    {
                        <form asp-controller="Home" asp-action="CheckoutCart" method="post">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Người nhận</label>
                                <input type="text" class="form-control bg-light" value="@User.Identity.Name" readonly>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-danger">Số điện thoại *</label>
                                <input type="text" name="SoDienThoai" class="form-control" placeholder="Ví dụ: 0987xxxxxx" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-danger">Địa chỉ nhận hàng *</label>
                                <textarea name="DiaChiGiaoHang" class="form-control" rows="3" placeholder="Ghi rõ số nhà, tên đường, phường/xã, quận/huyện..." required></textarea>
                            </div>

                            <button type="submit" class="btn btn-warning w-100 fw-black fs-5 py-3 rounded-pill shadow-sm text-dark">
                                XÁC NHẬN ĐẶT HÀNG
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</main>