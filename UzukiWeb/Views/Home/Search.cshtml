@model IEnumerable<UzukiWeb.Models.Truyen>
@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}

<main class="container pb-5" style="margin-top: 110px; min-height: 80vh;">
    <div class="d-flex align-items-center mb-2 border-bottom pb-3">
        <h2 class="fw-black m-0" style="color: #000066;"><i class="bi bi-search text-primary me-3"></i> KẾT QUẢ TÌM KIẾM</h2>
    </div>

    <div class="mb-4 text-muted fw-bold">
        Hiển thị <span class="text-danger">@ViewBag.TotalItems</span> kết quả cho từ khóa: <span class="text-primary">"@ViewBag.Keyword"</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-emoji-frown fs-1 text-muted"></i>
            <h4 class="mt-3 text-muted fw-bold">Không tìm thấy bộ truyện nào.</h4>
            <p class="text-muted">Vui lòng thử lại với từ khóa khác (Ví dụ: Solo, Makeine...)!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-3 col-lg-2">
                    <a href="/Home/Detail/@item.Id" class="text-decoration-none">
                        <div class="comic-card h-100 shadow-sm rounded-4 overflow-hidden position-relative">
                            @if (item.GiaCoin > 0)
                            {
                                <span class="badge-vip">VIP</span>
                            }
                            else
                            {

                                <span class="badge-free">FREE</span>
                            }

                            <img src="~/images/@item.AnhBia" class="comic-cover w-100" style="aspect-ratio: 2/3; object-fit: cover;">

                            <div class="comic-info p-3">
                                <h6 class="comic-title text-dark fw-bold mb-1 text-truncate-2">@item.TenTruyen</h6>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <small class="text-muted"><i class="bi bi-list-ul"></i> @(item.Chuongs?.Count ?? 0) Chương</small>
                                    <span class="badge bg-secondary" style="font-size: 0.7rem;">@item.DanhMuc?.TenDanhMuc</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</main>