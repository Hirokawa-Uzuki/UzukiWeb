@model IEnumerable<UzukiWeb.Models.Truyen>
@{
    ViewData["Title"] = "Đang Khuyến Mãi";
}

<main class="container main-content pb-5" style="min-height: 80vh; padding-top: 110px;">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h3 class="fw-black m-0 text-danger"><i class="bi bi-tags-fill me-3"></i>TRUYỆN ĐANG GIẢM GIÁ (HOT SALE)</h3>
    </div>

    <div class="row g-3 g-md-4 mb-5">
        @foreach (var item in Model)
        {
            int giaMoi = item.GiaCoin - (item.GiaCoin * item.PhanTramGiam / 100);

            <div class="col-6 col-md-3 col-lg-2">
                <a href="/Home/Detail/@item.Id" class="text-decoration-none">
                    <div class="comic-card h-100 d-flex flex-column">
                        <span class="badge bg-danger position-absolute top-0 start-0 m-2 shadow-sm shake-anim fs-6" style="z-index: 3;">-@item.PhanTramGiam%</span>
                        <img src="~/images/@item.AnhBia" class="comic-cover" alt="@item.TenTruyen">
                        <div class="comic-info p-2 flex-grow-1 d-flex flex-column text-center">
                            <div class="comic-title" style="font-size: 0.95rem;">@item.TenTruyen</div>
                            <div class="mt-auto d-flex justify-content-center align-items-end gap-2 mt-2">
                                <span class="text-muted text-decoration-line-through small">@item.GiaCoin</span>
                                <span class="text-danger fw-black fs-5">@giaMoi <i class="bi bi-coin fs-6"></i></span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</main>