@model IEnumerable<UzukiWeb.Models.SanPham>
@{
    ViewData["Title"] = "Cửa Hàng (Shop)";
}

<main class="container pb-5" style="margin-top: 110px; min-height: 80vh;">

    <div class="d-flex align-items-center justify-content-between border-bottom pb-3 mb-4">
        <h2 class="fw-black m-0" style="color: #000066;"><i class="bi bi-shop text-warning me-2"></i> UZUKI MERCH & SÁCH</h2>
        <a href="/Home/Cart" class="btn btn-outline-primary rounded-pill fw-bold">
            <i class="bi bi-cart3"></i> Đến Giỏ Hàng
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i><strong>@TempData["Success"]</strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4 mb-5">
        @foreach (var item in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden transition-hover">
                    <img src="~/images/@item.AnhBia" class="card-img-top" style="aspect-ratio: 1/1; object-fit: cover;" alt="@item.TenSanPham">
                    <div class="card-body d-flex flex-column text-center bg-light">
                        <h6 class="fw-bold text-truncate-2 mb-2" style="height: 40px;">@item.TenSanPham</h6>
                        <h5 class="text-danger fw-black mb-3">@item.Gia.ToString("N0") đ</h5>

                        <form asp-controller="Home" asp-action="AddToCart" method="post" class="mt-auto">
                            <input type="hidden" name="productId" value="@item.Id" />
                            <button type="submit" class="btn btn-warning rounded-pill fw-bold w-100 shadow-sm">
                                <i class="bi bi-cart-plus me-1"></i> Thêm vào giỏ
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</main>