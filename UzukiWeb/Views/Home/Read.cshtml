@model UzukiWeb.Models.Chuong
@{
    ViewData["Title"] = Model.TenChuong + " - " + Model.Truyen?.TenTruyen;
    var tatCaChuong = ViewBag.TatCaChuong as List<UzukiWeb.Models.Chuong>;
}

<div class="container-fluid pb-5" style="margin-top: 100px; background-color: #fafafa; min-height: 100vh;">
    <div class="container" style="max-width: 900px;">

        <div class="text-center mb-4 pt-4">
            <h3 class="fw-black text-primary">@Model.Truyen?.TenTruyen</h3>
            <h5 class="text-muted fw-bold">@Model.TenChuong</h5>
        </div>

        <div class="d-flex justify-content-center align-items-center gap-2 mb-4 bg-white p-3 rounded-pill shadow-sm border">
            @if (ViewBag.ChuongTruoc != null)
            {
                <a href="/Home/Read/@ViewBag.ChuongTruoc" class="btn btn-outline-primary rounded-pill fw-bold"><i class="bi bi-chevron-left"></i> Trước</a>
            }
            else
            {
                <button class="btn btn-outline-secondary rounded-pill fw-bold" disabled><i class="bi bi-chevron-left"></i> Trước</button>
            }

            <a href="/Home/Detail/@Model.TruyenId" class="btn btn-primary rounded-pill fw-bold px-4">
                <i class="bi bi-list"></i> Mục Lục
            </a>

            @if (ViewBag.ChuongSau != null)
            {
                <a href="/Home/Read/@ViewBag.ChuongSau" class="btn btn-outline-primary rounded-pill fw-bold">Sau <i class="bi bi-chevron-right"></i></a>
            }
            else
            {
                <button class="btn btn-outline-secondary rounded-pill fw-bold" disabled>Sau <i class="bi bi-chevron-right"></i></button>
            }
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4 p-md-5 reading-content" style="font-size: 1.25rem; line-height: 1.8; color: #333;">

                @if (string.IsNullOrEmpty(Model.NoiDung))
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-journal-x fs-1"></i>
                        <p class="mt-3">Nội dung chương đang được cập nhật...</p>
                    </div>
                }
                else
                {
                    @Html.Raw(Model.NoiDung)
                }

            </div>
        </div>

        <div class="d-flex justify-content-center align-items-center gap-2 pb-4">
            @if (ViewBag.ChuongTruoc != null)
            {
                <a href="/Home/Read/@ViewBag.ChuongTruoc" class="btn btn-outline-primary rounded-pill fw-bold"><i class="bi bi-chevron-left"></i> Chương Trước</a>
            }
            <a href="/Home/Detail/@Model.TruyenId" class="btn btn-primary rounded-pill fw-bold px-4"><i class="bi bi-list"></i> Mục Lục</a>
            @if (ViewBag.ChuongSau != null)
            {
                <a href="/Home/Read/@ViewBag.ChuongSau" class="btn btn-outline-primary rounded-pill fw-bold">Chương Sau <i class="bi bi-chevron-right"></i></a>
            }
        </div>
    </div>
</div>

<style>
    /* Chỉnh cho ảnh trong truyện tranh vừa khít màn hình điện thoại */
    .reading-content img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 0 auto;
    }
</style>