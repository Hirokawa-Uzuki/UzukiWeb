@{
    ViewData["Title"] = "Trang Chủ";
}
@model IEnumerable<UzukiWeb.Models.Truyen>

@if (ViewBag.KhuyenMaiBanner != null)
{
    var km = ViewBag.KhuyenMaiBanner;
    <div class="floating-side-banner-container d-none d-xl-flex" id="floatingBanner">
        <div class="banner-content">
            <a href="@(string.IsNullOrEmpty(km.Link) ? "#" : km.Link)">
                <img src="~/images/@km.HinhAnh" alt="Khuyến mãi" class="rounded-3 shadow transition-hover">
            </a>
        </div>
        <button class="banner-toggle-btn shadow" id="toggleBannerBtn">
            <i class="bi bi-caret-left-fill"></i>
        </button>
    </div>
}

<main class="container main-content pb-5" style="min-height: 80vh; padding-top: 100px;">

    <div class="swiper myUzukiSwiper mb-5">
        <div class="swiper-wrapper">
            @if (ViewBag.Slides != null)
            {
                foreach (var slide in ViewBag.Slides)
                {
                    <div class="swiper-slide">
                        <a href="@(string.IsNullOrEmpty(slide.Link) ? "#" : slide.Link)">
                            <img src="~/images/@slide.HinhAnh" alt="Banner Slide">
                        </a>
                    </div>
                }
            }
        </div>
        <div class="swiper-pagination"></div>
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-9">

            <div class="d-flex align-items-center mb-3 p-3 glass-box border-0 rounded-4 shadow-sm">
                <h4 class="section-title m-0 text-danger"><i class="bi bi-trophy-fill text-warning me-2"></i> RANKING TOP 10</h4>
                <a href="/Home/Ranking" class="ms-auto text-decoration-none fw-bold" style="color: #00aaff;">Xem tất cả <i class="bi bi-chevron-right"></i></a>
            </div>

            <div class="position-relative shelf-container mb-5">
                <div class="swiper shelfSwiper pb-3 px-2">
                    <div class="swiper-wrapper">
                        @{
                            int rank = 1;
                        }
                        @foreach (var item in ViewBag.Ranking)
                        {
                            string rankClass = rank == 1 ? "rank-1" : (rank == 2 ? "rank-2" : "");
                            <div class="swiper-slide">
                                <a href="/Home/Detail/@item.Id" class="text-decoration-none">
                                    <div class="comic-card">
                                        <div class="rank-badge @rankClass">@rank</div>
                                        <img src="~/images/@item.AnhBia" class="comic-cover" alt="@item.TenTruyen">
                                        <div class="comic-info p-2 text-center">
                                            <div class="comic-title fs-6">@item.TenTruyen</div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                            rank++;
                        }
                    </div>
                </div>
                <div class="swiper-button-prev shelf-prev"></div>
                <div class="swiper-button-next shelf-next"></div>
            </div>

            <div class="d-flex align-items-center mb-3">
                <h4 class="section-title m-0">⚡ TRUYỆN MỚI CẬP NHẬT</h4>
                <a href="/Home/Manga" class="ms-auto text-decoration-none fw-bold" style="color: #00aaff;">Xem tất cả <i class="bi bi-chevron-right"></i></a>
            </div>

            <div class="row g-3 mb-5">
                @foreach (var truyen in Model)
                {
                    <div class="col-6 col-md-3">
                        <a href="/Home/Detail/@truyen.Id" class="text-decoration-none">
                            <div class="comic-card h-100 d-flex flex-column">
                                @if (truyen.GiaCoin == 0)
                                {
                                    <span class="badge badge-free position-absolute top-0 end-0 m-2 shadow-sm" style="z-index: 3;">FREE</span>
                                }
                                else
                                {
                                    <span class="badge badge-vip position-absolute top-0 end-0 m-2 shadow-sm" style="z-index: 3;">VIP</span>
                                }

                                <img src="~/images/@truyen.AnhBia" class="comic-cover" alt="@truyen.TenTruyen">
                                <div class="comic-info p-2 flex-grow-1 d-flex flex-column text-center">
                                    <div class="comic-title" style="font-size: 0.95rem;">@truyen.TenTruyen</div>
                                    <div class="comic-genre mt-auto text-muted small">@truyen.DanhMuc?.TenDanhMuc</div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <div class="d-flex align-items-center mb-3">
                <h4 class="section-title m-0" style="border-color: #ff3366;">📖 LIGHT NOVEL NỔI BẬT</h4>
                <a href="/Home/LightNovel" class="ms-auto text-decoration-none fw-bold" style="color: #ff3366;">Thêm Light Novel <i class="bi bi-chevron-right"></i></a>
            </div>
            <div class="row g-3 mb-5">
                @foreach (var ln in ViewBag.LightNovel)
                {
                    <div class="col-6 col-md-3">
                        <a href="/Home/Detail/@ln.Id" class="text-decoration-none">
                            <div class="comic-card h-100 d-flex flex-column">
                                <img src="~/images/@ln.AnhBia" class="comic-cover" alt="@ln.TenTruyen">
                                <div class="comic-info p-2 flex-grow-1 d-flex flex-column text-center">
                                    <div class="comic-title" style="font-size: 0.95rem;">@ln.TenTruyen</div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-3">

            @if (!User.Identity!.IsAuthenticated)
            {
                <div class="sidebar-box glass-box text-center p-4 mb-4 rounded-4 shadow-sm border-0">
                    <h6 class="fw-bold mb-3" style="color: #000066;">Lần đầu đến với UZUKI?</h6>
                    <p class="text-muted small mb-3">Đăng ký ngay để nhận 500 Coin miễn phí và mở khóa truyện VIP!</p>
                    <a href="/Account/Register" class="btn btn-primary w-100 rounded-pill fw-bold mb-2">Đăng Ký Thành Viên</a>
                    <a href="/Account/Login" class="btn btn-outline-secondary w-100 rounded-pill fw-bold bg-white">Đăng Nhập</a>
                </div>
            }
            else
            {
                <div class="sidebar-box glass-box text-center p-4 mb-4 rounded-4 shadow-sm border border-warning border-2">
                    <div class="mb-3">
                        <img src="https://placehold.co/60x60/00aaff/fff?text=U" class="rounded-circle border border-3 border-white shadow-sm" alt="Avatar">
                    </div>
                    <h6 class="fw-black mb-1" style="color: #000066;">Chào mừng, @User.Identity.Name!</h6>
                    <div class="d-flex justify-content-center align-items-center gap-2 my-2">
                        <span class="badge bg-danger rounded-pill px-3 py-2 fs-6 shadow-sm"><i class="bi bi-gem"></i> @User.FindFirst("Coin")?.Value Coin</span>
                    </div>
                    <a href="/Home/Premium" class="btn btn-warning w-100 rounded-pill fw-bold text-dark mt-2 shadow-sm"><i class="bi bi-wallet2"></i> Nạp thêm Coin</a>
                </div>
            }

            <div class="sidebar-box p-4 rounded-4 bg-white shadow-sm border-0">
                <h6 class="fw-bold mb-4 border-bottom pb-2" style="color: #ff8800;"><i class="bi bi-cart-check"></i> SÁCH BÁN CHẠY</h6>

                @if (ViewBag.SachBanChay != null)
                {
                    foreach (var item in ViewBag.SachBanChay)
                    {
                        <a href="/Home/Shop" class="text-decoration-none text-dark d-block mb-3 border-bottom pb-3">
                            <div class="d-flex align-items-center transition-hover">
                                <img src="~/images/@item.AnhBia" style="width: 60px; height: 90px; object-fit: cover;" class="rounded shadow-sm me-3" alt="@item.TenSanPham">
                                <div>
                                    <div class="fw-bold text-truncate" style="max-width: 140px; font-size: 0.95rem;">@item.TenSanPham</div>
                                    <div class="small text-danger fw-bold mt-1" style="font-size: 0.9rem;">@String.Format("{0:N0}", item.Gia) đ</div>
                                </div>
                            </div>
                        </a>
                    }
                }

                <a href="/Home/Shop" class="btn btn-outline-warning w-100 rounded-pill fw-bold text-dark mt-2">Đến Shop <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="sidebar-box p-4 rounded-4 bg-white shadow-sm border-0 mt-4">
                <div class="d-flex align-items-center mb-4 border-bottom pb-2">
                    <h6 class="fw-bold m-0" style="color: #ff3366;"><i class="bi bi-star-fill text-warning me-2"></i>GÓC ĐỀ CỬ</h6>
                    <a href="/Home/Recommend" class="ms-auto text-decoration-none small text-muted">Xem thêm <i class="bi bi-chevron-right"></i></a>
                </div>
                @foreach (var rcm in ViewBag.Recommend)
                {
                    <a href="/Home/Detail/@rcm.Id" class="text-decoration-none text-dark d-block mb-3 border-bottom pb-3">
                        <div class="d-flex transition-hover">
                            <div class="position-relative me-3" style="min-width: 75px; max-width: 75px;">
                                <span class="badge bg-danger position-absolute top-0 start-0 translate-middle-y ms-1 shake-anim" style="font-size: 0.6rem; z-index: 2;">HOT</span>
                                <img src="~/images/@rcm.AnhBia" class="rounded shadow-sm w-100" style="aspect-ratio: 2/3; object-fit: cover;" alt="Cover">
                            </div>
                            <div class="d-flex flex-column justify-content-center">
                                <div class="mb-1"><span class="badge border border-primary text-primary px-1 py-0 rounded-1" style="font-size: 0.65rem;">@rcm.DanhMuc?.TenDanhMuc</span></div>
                                <div class="fw-bold text-truncate-2" style="font-size: 0.95rem; line-height: 1.3; margin-bottom: 4px;">@rcm.TenTruyen</div>
                                <div class="text-danger fw-bold mt-1" style="font-size: 0.9rem;">@(rcm.GiaCoin == 0 ? "Miễn phí" : rcm.GiaCoin + " Coin")</div>
                            </div>
                        </div>
                    </a>
                }
            </div>

            <div class="sidebar-box p-4 rounded-4 bg-white shadow-sm border-0 mt-4 border-top border-danger border-4">
                <div class="d-flex align-items-center mb-4 border-bottom pb-2">
                    <h6 class="fw-bold m-0 text-danger"><i class="bi bi-tags-fill me-2"></i>HOT SALE</h6>
                    <a href="/Home/HotSale" class="ms-auto text-decoration-none small text-muted">Tất cả <i class="bi bi-chevron-right"></i></a>
                </div>
                @foreach (var sale in ViewBag.HotSale)
                {
                    int giaMoi = sale.GiaCoin - (sale.GiaCoin * sale.PhanTramGiam / 100);
                    <a href="/Home/Detail/@sale.Id" class="text-decoration-none text-dark d-block mb-3 border-bottom pb-3">
                        <div class="d-flex transition-hover">
                            <div class="position-relative me-3" style="min-width: 75px; max-width: 75px;">
                                <span class="badge bg-danger position-absolute top-0 start-0 translate-middle ms-2 shadow-sm shake-anim" style="font-size: 0.7rem; z-index: 2; border-radius: 4px;">-@sale.PhanTramGiam%</span>
                                <img src="~/images/@sale.AnhBia" class="rounded shadow-sm w-100" style="aspect-ratio: 2/3; object-fit: cover;" alt="Cover">
                            </div>
                            <div class="d-flex flex-column justify-content-center w-100">
                                <div class="fw-bold text-truncate-2" style="font-size: 0.95rem; line-height: 1.3; margin-bottom: 4px;">@sale.TenTruyen</div>
                                <div class="d-flex align-items-end mt-auto">
                                    <span class="text-muted text-decoration-line-through me-2" style="font-size: 0.8rem;">@sale.GiaCoin</span>
                                    <span class="text-danger fw-black" style="font-size: 1.05rem;">@giaMoi Coin</span>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>
</main>