@model IEnumerable<UzukiWeb.Models.Truyen>
@{
    ViewData["Title"] = "Kho Webtoon / Manhwa";
}

<main class="container main-content pb-5" style="min-height: 80vh; padding-top: 110px;">

    @if (ViewBag.FeaturedManhwa != null)
    {
        var fm = (UzukiWeb.Models.Truyen)ViewBag.FeaturedManhwa;
        <div class="manhwa-hero-banner mb-5 bg-dark rounded-4 position-relative overflow-hidden shadow">
            <!-- Ảnh bìa Manhwa lấy từ Database -->
            <img src="~/images/@fm.AnhBia" class="position-absolute end-0 h-100 opacity-50 w-50"
                 style="object-fit: cover; mask-image: linear-gradient(to left, black, transparent);" alt="@fm.TenTruyen">

            <div class="position-relative z-1 p-5 text-white w-75">
                <span class="badge bg-warning text-dark mb-2 px-3 py-2 fw-bold">ĐỘC QUYỀN <i class="bi bi-star-fill"></i></span>

                <!-- Tên truyện động -->
                <h1 class="fw-black mb-3">@fm.TenTruyen</h1>

                <!-- Mô tả động -->
                <p class="opacity-75 mb-4 text-truncate-2">@fm.MoTa</p>

                <!-- Link chi tiết động -->
                <a href="/Home/Detail/@fm.Id" class="btn btn-light rounded-pill fw-bold px-4 py-2 text-dark">
                    <i class="bi bi-book-half"></i> Đọc Truyện Ngay
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Khoảng trống nếu không có tiêu điểm -->
        <div class="mb-4"></div>
    }

    <div class="d-flex align-items-center mb-4 gap-3 flex-wrap flex-md-nowrap">
        <h4 class="fw-black m-0 flex-shrink-0" style="color: #000066;"><i class="bi bi-phone text-success me-2"></i>KHO MANHWA</h4>
        <div class="filter-tags-scroll flex-grow-1">
            <a href="/Home/Manhwa?sortBy=@ViewBag.CurrentSort&keyword=@ViewBag.Keyword" class="filter-tag @(ViewBag.CurrentGenre == null ? "active" : "")">Tất cả</a>
            @if (ViewBag.ListTheLoai != null)
            {
                foreach (var genre in ViewBag.ListTheLoai)
                {
                    <a href="/Home/Manhwa?genreId=@genre.Id&sortBy=@ViewBag.CurrentSort&keyword=@ViewBag.Keyword" class="filter-tag @(ViewBag.CurrentGenre == genre.Id ? "active" : "")">@genre.TenTheLoai</a>
                }
            }
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light">
        <span class="text-muted fw-bold">Hiển thị <span class="text-danger">@ViewBag.TotalItems</span> kết quả</span>
        <div class="dropdown">
            <button class="btn btn-light bg-white border-0 fw-bold text-primary shadow-sm rounded-pill px-3 py-2 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-sort-down me-1"></i> Sắp xếp
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 p-2">
                <li><a class="dropdown-item rounded-3 mb-1" href="/Home/Manhwa?sortBy=new&genreId=@ViewBag.CurrentGenre&keyword=@ViewBag.Keyword"><i class="bi bi-clock-history me-2"></i> Mới cập nhật</a></li>
                <li><a class="dropdown-item rounded-3 mb-1" href="/Home/Manhwa?sortBy=view&genreId=@ViewBag.CurrentGenre&keyword=@ViewBag.Keyword"><i class="bi bi-fire me-2"></i> Xem nhiều nhất</a></li>
            </ul>
        </div>
    </div>

    <div class="row g-3 g-md-4 mb-5">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5"><h5 class="text-muted">Không có truyện nào.</h5></div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-3 col-lg-2">
                    <a href="/Home/Detail/@item.Id" class="text-decoration-none">
                        <div class="comic-card h-100 d-flex flex-column">
                            @if (item.GiaCoin == 0)
                            {
                                <span class="badge badge-free position-absolute top-0 end-0 m-2 shadow-sm" style="z-index: 3;">FREE</span>
                            }
                            else
                            {

                                <span class="badge badge-vip position-absolute top-0 end-0 m-2 shadow-sm" style="z-index: 3;">VIP</span>
                            }
                            <img src="~/images/@item.AnhBia" class="comic-cover" alt="@item.TenTruyen">
                            <div class="comic-info p-2 flex-grow-1 d-flex flex-column text-center">
                                <div class="comic-title" style="font-size: 0.95rem;">@item.TenTruyen</div>
                                @{
                                    var chuongMoi = item.Chuongs?.OrderByDescending(c => c.SoThuTu).FirstOrDefault();
                                }
                                <div class="mt-auto text-muted small text-truncate">@(chuongMoi != null ? chuongMoi.TenChuong : "Đang cập nhật")</div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</main>