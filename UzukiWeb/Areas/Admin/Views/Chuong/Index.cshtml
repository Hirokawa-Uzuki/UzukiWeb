@model IEnumerable<UzukiWeb.Models.Chuong>
@{
    ViewData["Title"] = "Quản Lý Chương";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var truyen = ViewBag.Truyen as UzukiWeb.Models.Truyen;
}

<div class="container-fluid p-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-bold m-0 text-primary">
                        <i class="bi bi-list-ol me-2"></i> Các Chương Của: <span class="text-danger">@truyen?.TenTruyen</span>
                    </h4>
                    <a href="/Admin/Truyen/Index" class="text-decoration-none fw-bold mt-2 d-inline-block text-muted">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách Truyện
                    </a>
                </div>
                <a href="/Admin/Chuong/Create?truyenId=@truyen?.Id" class="btn btn-success fw-bold rounded-pill px-4 shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Thêm Chương Mới
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle border">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 80px;">STT</th>
                            <th>Tên Chương</th>
                            <th class="text-center">Giá Mở Khóa</th>
                            <th class="text-center" style="width: 150px;">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="4" class="text-center py-5 text-muted">Truyện này chưa được đăng chương nào.</td></tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold fs-5 text-muted">@item.SoThuTu</td>
                                <td class="fw-bold text-dark">@item.TenChuong</td>
                                <td class="text-center">
                                    @if (item.GiaCoin > 0)
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow-sm"><i class="bi bi-coin"></i> @item.GiaCoin Coin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm">Miễn phí</span>
                                    }
                                </td>
                                
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-3">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa chương này?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3">
                                            <i class="bi bi-trash3"></i> Xóa
                                        </button>
                                    </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>