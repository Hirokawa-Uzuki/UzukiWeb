@model UzukiWeb.Models.DanhMuc
@{
    ViewData["Title"] = "Sửa Danh Mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold m-0"><i class="bi bi-pencil-square text-warning me-2"></i> Chỉnh Sửa Danh Mục</h3>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-bold"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 col-md-6">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label class="form-label fw-bold">Tên Danh Mục <span class="text-danger">*</span></label>
                    <input asp-for="TenDanhMuc" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-warning w-100 rounded-pill fw-bold py-2 shadow-sm">
                    <i class="bi bi-save me-1"></i> CẬP NHẬT LẠI
                </button>
            </form>
        </div>
    </div>
</div>