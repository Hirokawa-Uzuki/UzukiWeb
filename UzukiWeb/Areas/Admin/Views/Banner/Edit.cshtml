@model UzukiWeb.Models.Banner
@{
    ViewData["Title"] = "Sửa Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-4 w-50 mx-auto mt-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
        <h4 class="fw-bold text-primary"><i class="bi bi-pencil-square"></i> CẬP NHẬT BANNER</h4>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <!-- BẮT BUỘC PHẢI CÓ HIDDEN ID -->
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="HinhAnh" /> <!-- Giữ lại tên ảnh cũ nếu không up ảnh mới -->

            <div class="mb-3 text-center">
                <label class="form-label fw-bold d-block">Ảnh Banner Hiện Tại</label>
                <img src="~/images/@Model.HinhAnh" class="img-fluid rounded border shadow-sm mb-2" style="max-height: 150px; object-fit: contain; background: #f8f9fa;" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tải ảnh Banner mới (Nếu muốn đổi)</label>
                <input type="file" name="AnhUpload" class="form-control" accept="image/*" />
                <small class="text-muted">Bỏ trống nếu muốn giữ nguyên ảnh cũ</small>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Vị trí hiển thị <span class="text-danger">*</span></label>
                <select asp-for="ViTri" class="form-select" required>
                    <option value="Slide">Trượt (Slide chính)</option>
                    <option value="KhuyenMai">Banner nổi (Bên trái)</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Đường dẫn khi Click (Link)</label>
                <input asp-for="Link" class="form-control" placeholder="Ví dụ: /Home/Premium hoặc /Home/Detail/1" />
            </div>

            <div class="mb-4 form-check form-switch">
                <input class="form-check-input" type="checkbox" asp-for="TrangThai">
                <label class="form-check-label fw-bold text-primary" for="TrangThai">Cho phép hiển thị Banner này</label>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary fw-bold"><i class="bi bi-save"></i> LƯU THAY ĐỔI</button>
                <a asp-action="Index" class="btn btn-light text-secondary border">Hủy, Quay lại</a>
            </div>
        </form>
    </div>
</div>