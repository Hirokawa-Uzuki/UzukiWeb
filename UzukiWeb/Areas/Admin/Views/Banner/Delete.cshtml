@model UzukiWeb.Models.Banner
@{
    ViewData["Title"] = "Xác nhận Xóa Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-4 w-50 mx-auto mt-5 p-4 text-center">
    <div class="mb-3">
        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
    </div>
    <h3 class="fw-bold text-danger mb-3">CẢNH BÁO XÓA!</h3>
    <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa Banner này khỏi hệ thống không?</p>

    <!-- Khung hiển thị ảnh Banner sắp bị xóa -->
    <div class="border rounded-3 p-3 text-center mb-4 bg-light mx-auto" style="max-width: 90%;">
        <img src="~/images/@Model.HinhAnh" alt="Banner" class="img-fluid rounded shadow-sm mb-2" style="max-height: 120px; object-fit: contain;" />
        <div class="mt-2">
            <span class="badge bg-info text-dark">Vị trí: @Model.ViTri</span>
        </div>
    </div>

    <!-- Nút xác nhận -->
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-center gap-3">
            <button type="submit" class="btn btn-danger fw-bold px-4 rounded-pill shadow-sm">
                <i class="bi bi-trash"></i> Xác Nhận Xóa Thật
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-4 rounded-pill">
                <i class="bi bi-x-circle"></i> Hủy, Quay lại
            </a>
        </div>
    </form>
</div>