@model IEnumerable<UzukiWeb.Models.Banner>
@{
    ViewData["Title"] = "Quản Lý Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-4 w-100 mx-auto mt-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
        <h4 class="fw-bold text-primary mb-0"><i class="bi bi-images text-success"></i> QUẢN LÝ BANNER QUẢNG CÁO</h4>
        <a asp-action="Create" class="btn btn-success fw-bold rounded-pill shadow-sm"><i class="bi bi-plus-lg"></i> Thêm Banner Mới</a>
    </div>
    <div class="card-body p-4">
        <table class="table table-hover align-middle text-center">
            <thead class="table-light">
                <tr>
                    <th>STT</th>
                    <th>Hình Ảnh</th>
                    <th>Vị Trí</th>
                    <th>Đường Dẫn (Link)</th>
                    <th>Trạng Thái</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-muted py-4">Chưa có banner nào trong hệ thống. Hãy thêm mới!</td></tr>
                }
                @{
                    int stt = 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <!-- IN RA STT VÀ TỰ ĐỘNG CỘNG 1 -->
                        <td class="fw-bold text-muted">@(stt++)</td>

                        <td>
                            <img src="~/images/@item.HinhAnh" alt="Banner" class="rounded shadow-sm" style="height: 60px; object-fit: contain; background: #f8f9fa; padding: 2px;">
                        </td>
                        <td>
                            <span class="badge bg-info text-dark shadow-sm">@item.ViTri</span>
                        </td>
                        <td class="text-start">
                            @(string.IsNullOrEmpty(item.Link) ? "Không có" : item.Link)
                        </td>
                        <td>
                            @if (item.TrangThai)
                            {
                                <span class="badge bg-success rounded-pill"><i class="bi bi-check-circle"></i> Đang hiện</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill"><i class="bi bi-eye-slash"></i> Đang ẩn</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3"><i class="bi bi-pencil-square"></i> Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>