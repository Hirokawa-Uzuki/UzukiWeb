@model IEnumerable<UzukiWeb.Models.Truyen>

@{
    ViewData["Title"] = "Danh Sách Truyện";
    // Báo cho .NET biết dùng layout của Admin thay vì layout web ngoài
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card-custom p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold m-0"><i class="bi bi-list-ul me-2"></i>Tất Cả Truyện</h4>
        <a asp-action="Create" class="btn btn-success fw-bold rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Thêm Truyện Mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light">
                <tr>
                    <th>Bìa</th>
                    <th>Tên Truyện</th>
                    <th>Tác Giả</th>
                    <th>Thể Loại</th>
                    <th>Giá Coin</th>
                    <th>Ngày Cập Nhật</th>
                    <th class="text-center">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="~/images/@item.AnhBia" style="width: 50px; height: 75px; object-fit: cover;" class="rounded shadow-sm" alt="Bìa" />
                        </td>
                        <td class="fw-bold text-primary">@item.TenTruyen</td>
                        <td>@item.TacGia</td>
                        <td><span class="badge bg-secondary">@item.DanhMuc?.TenDanhMuc</span></td>
                        <td>
                            @if (item.GiaCoin == 0)
                            {
                                <span class="badge bg-success">Miễn phí</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-coin"></i> @item.GiaCoin</span>
                            }
                        </td>
                        <td>@item.NgayCapNhat.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary shadow-sm"><i class="bi bi-pencil-square"></i></a>
                            <a href="/Admin/Chuong/Index?truyenId=@item.Id" class="btn btn-sm btn-outline-info shadow-sm" title="Quản lý Chương"><i class="bi bi-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger shadow-sm"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
