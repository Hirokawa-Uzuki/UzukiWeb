@model UzukiWeb.Models.TaiKhoan
@{
    ViewData["Title"] = "Sửa Người Dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-4 w-50 mx-auto mt-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
        <h4 class="fw-bold text-primary text-center"><i class="bi bi-person-gear"></i> CẬP NHẬT TÀI KHOẢN</h4>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label fw-bold">Tên Đăng Nhập</label>
                <input asp-for="TenDangNhap" class="form-control bg-light" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Email</label>
                <input asp-for="Email" class="form-control bg-light" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-danger">Số Coin</label>
                <input asp-for="SoDuCoin" type="number" class="form-control fw-bold text-danger" required />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Vai Trò</label>
                <select asp-for="VaiTro" class="form-select fw-bold text-primary">
                    <option value="Khách Hàng">Khách Hàng</option>
                    <option value="Admin">Quản Trị Viên (Admin)</option>
                </select>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary fw-bold"><i class="bi bi-save"></i> LƯU THAY ĐỔI</button>
                <a asp-action="Index" class="btn btn-light text-secondary border">Hủy, Quay lại</a>
            </div>
        </form>
    </div>
</div>