@model UzukiWeb.Models.SanPham
@{
    ViewData["Title"] = "Thêm Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h3 class="fw-bold text-success mb-4"><i class="bi bi-plus-circle"></i> THÊM SẢN PHẨM MỚI</h3>
<div class="card shadow-sm border-0 p-4">
    <form asp-action="Create" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên Sản Phẩm</label>
                    <input asp-for="TenSanPham" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Giá Bán (VNĐ)</label>
                    <input asp-for="Gia" type="number" class="form-control text-danger fw-bold" required />
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tải lên Ảnh Bìa</label>
                    <input type="file" name="AnhBiaFile" class="form-control" accept="image/*" required />
                </div>
            </div>
        </div>
        <hr />
        <button type="submit" class="btn btn-primary px-5 fw-bold"><i class="bi bi-save"></i> LƯU SẢN PHẨM</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
    </form>
</div>