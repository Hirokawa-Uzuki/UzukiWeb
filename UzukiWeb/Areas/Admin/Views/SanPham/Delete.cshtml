@model UzukiWeb.Models.SanPham
@{
    ViewData["Title"] = "Xác nhận Xóa";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-4 w-50 mx-auto mt-5 p-4 text-center">
    <div class="mb-3">
        <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
    </div>
    <h3 class="fw-bold text-danger mb-3">CẢNH BÁO XÓA!</h3>
    <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa vĩnh viễn sản phẩm này khỏi hệ thống?</p>

    <!-- Khung thông tin item sắp bị xóa -->
    <div class="border rounded-3 p-3 text-start d-flex align-items-center mb-4 bg-light">
        <img src="~/images/@Model.AnhBia" alt="Ảnh" class="rounded me-3" style="width: 60px; height: 80px; object-fit: cover;" />
        <div>
            <h5 class="fw-bold text-dark mb-1">@Model.TenSanPham</h5>
            <span class="badge bg-secondary">Shop / Merch</span>
        </div>
    </div>

    <!-- Nút xác nhận -->
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-center gap-3">
            <button type="submit" class="btn btn-danger fw-bold px-4 rounded-pill">
                <i class="bi bi-trash"></i> Xác Nhận Xóa Thật
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-4 rounded-pill">
                <i class="bi bi-x-circle"></i> Hủy, Quay lại
            </a>
        </div>
    </form>
</div>