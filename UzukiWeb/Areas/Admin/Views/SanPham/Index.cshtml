@model IEnumerable<UzukiWeb.Models.SanPham>
@{
    ViewData["Title"] = "Quản lý Shop";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">🛍️ Quản Lý Sản Phẩm Shop</h2>
    <a asp-action="Create" class="btn btn-success fw-bold"><i class="bi bi-plus-circle"></i> Thêm Sản Phẩm Mới</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ảnh</th>
                    <th>Tên Sản Phẩm</th>
                    <th>Giá Bán</th>
                    <th class="text-center">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><img src="~/images/@item.AnhBia" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;" /></td>
                        <td class="fw-bold text-dark">@item.TenSanPham</td>
                        <td class="text-danger fw-bold">@item.Gia.ToString("N0") đ</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="bi bi-pencil-square"></i> Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>