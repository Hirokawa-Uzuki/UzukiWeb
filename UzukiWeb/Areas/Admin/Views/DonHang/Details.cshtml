@model UzukiWeb.Models.DonHang
@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold m-0"><i class="bi bi-receipt text-success me-2"></i> Chi Tiết Đơn Hàng #@Model.Id</h3>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-bold"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white fw-bold py-3"><i class="bi bi-person-lines-fill me-2"></i> Thông tin giao hàng</div>
                <div class="card-body">
                    <p class="mb-2"><strong>Khách hàng:</strong> @ViewBag.TenNguoiMua</p>
                    <p class="mb-2"><strong>Số điện thoại:</strong> <span class="text-primary fw-bold">@Model.SoDienThoai</span></p>
                    <p class="mb-2"><strong>Ngày đặt:</strong> @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-0"><strong>Địa chỉ:</strong> @Model.DiaChiGiaoHang</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white fw-bold py-3"><i class="bi bi-truck me-2"></i> Cập nhật trạng thái</div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Trạng thái hiện tại:</label>
                            <select name="TrangThai" class="form-select fw-bold text-primary">
                                <option value="@Model.TrangThai" hidden selected>@Model.TrangThai</option>

                                <option value="Chờ thanh toán">Chờ thanh toán</option>
                                <option value="Chờ xử lý (Đã thanh toán)">Chờ xử lý (Đã thanh toán)</option>
                                <option value="Đang giao hàng">Đang giao hàng</option>
                                <option value="Đã hoàn thành">Đã hoàn thành</option>
                                <option value="Đã hủy">Đã hủy</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success w-100 fw-bold rounded-pill">LƯU TRẠNG THÁI</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white fw-bold py-3"><i class="bi bi-cart-check-fill me-2"></i> Sản phẩm đã đặt</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Sản Phẩm</th>
                                    <th class="text-center">Đơn Giá</th>
                                    <th class="text-center">Số Lượng</th>
                                    <th class="text-end pe-4">Thành Tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ViewBag.ChiTietDonHang)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center py-2">
                                                <img src="~/images/@item.AnhBia" class="rounded shadow-sm me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                <div class="fw-bold">@item.TenSanPham</div>
                                            </div>
                                        </td>
                                        <td class="text-center text-muted">@item.DonGia.ToString("N0") đ</td>
                                        <td class="text-center fw-bold">x @item.SoLuong</td>
                                        <td class="text-end fw-black text-danger pe-4">@item.ThanhTien.ToString("N0") đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold fs-5">TỔNG CỘNG:</td>
                                    <td class="text-end fw-black text-danger fs-4 pe-4">@Model.TongTien.ToString("N0") đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>